<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the Room database from cloud backup (user data stays local) -->
        <exclude domain="database" path="skynet_news.db" />
        <exclude domain="database" path="skynet_news.db-shm" />
        <exclude domain="database" path="skynet_news.db-wal" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
