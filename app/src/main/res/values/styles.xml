<resources>

    <!-- Base application theme — Material Design 3 Light -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:statusBarColor">?attr/colorPrimaryContainer</item>
    </style>

    <!-- No-action-bar variant used by MainActivity -->
    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Overlays for AppBar -->
    <style name="ThemeOverlay.Material3.Dark.ActionBar"
        parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="ThemeOverlay.Material3.Light"
        parent="ThemeOverlay.AppCompat.Light" />

</resources>
